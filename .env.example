# ============================================================
# FITNESSW APP — Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env a git.
# ============================================================

# --- Flask ---
# Entorno: development | production | testing
FLASK_ENV=production

# Clave secreta para sesiones y CSRF.
# Genera una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-larga

# --- Base de datos (Supabase) ---
# Copia la connection string desde Supabase → Project Settings → Database → Connection string
# Usa el modo "Transaction pooler" (puerto 6543) para Railway
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Activar SSL para Supabase (siempre True en producción con Supabase)
DB_SSL=true

# --- Sesión ---
# True en producción (requiere HTTPS), False en desarrollo local
SESSION_COOKIE_SECURE=True

# Duración de la sesión en segundos (3600 = 1 hora)
PERMANENT_SESSION_LIFETIME=3600

# --- Logging ---
# Nivel: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_FILE=logs/fitness_app.log

# --- App ---
APP_NAME=FitnessW App
APP_VERSION=2.0.0
