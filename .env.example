# ============================================================
# FITNESSW APP - Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env a git.
# ============================================================

# --- Flask ---
# Entorno: development | production | testing
FLASK_ENV=development

# Clave secreta para sesiones y CSRF.
# Genera una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-larga

# --- Base de datos ---
# PostgreSQL local (desarrollo):
DATABASE_URL=postgresql://usuario:password@localhost:5432/fitness_app_dev

# PostgreSQL en Render (producción):
# DATABASE_URL=postgresql://user:pass@host/dbname

# --- Sesión ---
# True en producción (requiere HTTPS), False en desarrollo local
SESSION_COOKIE_SECURE=False

# Duración de la sesión en segundos (3600 = 1 hora)
PERMANENT_SESSION_LIFETIME=3600

# --- Logging ---
# Nivel: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_FILE=logs/fitness_app.log

# --- App ---
APP_NAME=FitnessW App
APP_VERSION=2.0.0
